# equity-intelligence — Environment Variables
# Copy to .env and fill in your keys.

# ─────────────────────────────────────────────
# US Market: Financial Datasets API
# https://financialdatasets.ai
# Required for US stock data (prices, financials, SEC filings)
# ─────────────────────────────────────────────
FINANCIAL_DATASETS_API_KEY=

# ─────────────────────────────────────────────
# JP Market: J-Quants API (JPX official)
# https://jpx-jquants.com/
# Required for JP stock prices and company master data
# NOTE: Free tier has 12-week price delay.
#       Financial statements require Premium plan.
# ─────────────────────────────────────────────
JQUANTS_MAIL_ADDRESS=
JQUANTS_PASSWORD=
# After first run, the refresh token is cached here:
# JQUANTS_REFRESH_TOKEN=  (auto-populated by client)

# ─────────────────────────────────────────────
# JP Market: EDINET API (FSA financial disclosures)
# https://api.edinet-fsa.go.jp/
# Required for JP filings (有価証券報告書, 四半期報告書, etc.)
# Apply at: https://disclosure2.edinet-fsa.go.jp/weee0010.aspx
# IMPORTANT: Server-side only. Do NOT expose in browser.
# ─────────────────────────────────────────────
EDINET_SUBSCRIPTION_KEY=

# ─────────────────────────────────────────────
# Optional: Exa Semantic Search
# https://exa.ai
# If absent, news search tool is disabled.
# Cost: $5/1,000 searches + $1/1,000 full-text pages
# ─────────────────────────────────────────────
EXASEARCH_API_KEY=

# ─────────────────────────────────────────────
# Walltalk output directory
# Where dossiers/theses/sessions are written.
# Default: ./output/walltalk  (relative to project root)
# ─────────────────────────────────────────────
# WALLTALK_OUTPUT_DIR=./output/walltalk

# ─────────────────────────────────────────────
# LLM (Claude Max — no API billing)
# Uses OAuth token from `claude auth` — no API key needed.
# Model: claude-opus-4-6 (default in agent.ts)
# ─────────────────────────────────────────────
# ANTHROPIC_API_KEY=  <- Leave empty if using Claude Max OAuth
