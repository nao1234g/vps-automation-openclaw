{
  "name": "OpenClaw VPS Automation",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",

  // Claude Code拡張設定（T019: Lane B devcontainer用）
  "customizations": {
    "vscode": {
      "extensions": [
        // Claude Code VS Code拡張機能
        // 拡張機能ID: anthropic.claude-code (VS Code Marketplace要確認)
        "anthropic.claude-code"
      ],
      "settings": {
        // ⚠️ 重要: bypassPermissionsはここでは設定できない。
        //   devcontainer内ではsettings.local.json（gitignored）が存在しない。
        //   Lane B devcontainerで自律実行する場合は
        //   .claude/settings.json の defaultMode を bypassPermissions にすること。
        //   または lane-b-devcontainer.sh の[2/4]警告を確認してから実行。
        "extensions.autoUpdate": true
      }
    }
  },

  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    // Node.js: claude CLI (npm install -g @anthropic-ai/claude-code) に必要
    "ghcr.io/devcontainers/features/node:1": {}
  },

  // ポートフォワーディング
  "forwardPorts": [3000, 5432, 5678, 8080],

  // Claude Code CLIインストール
  // Lane B devcontainer起動後、devcontainer内ターミナルで `claude` コマンドが使える
  "postCreateCommand": "npm install -g @anthropic-ai/claude-code && echo 'Claude Code CLI installed. IMPORTANT: check .claude/settings.json defaultMode for bypassPermissions before autonomous work.'",

  "remoteUser": "root"
}
